# ─── POLARIS · Variables de entorno (sección 8 de CLAUDE.md) ───
# Copia este archivo a .env (raíz) y apps/web/.env.local según aplique.
# NUNCA commitear secretos.

# Claude API (agent brain)
ANTHROPIC_API_KEY=

# Supabase (Postgres + Auth + Storage + Realtime + RLS)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Las mismas URL/anon key, expuestas al browser por Next.js:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Redis (BullMQ — worker de cadencias y crons)
REDIS_URL=redis://localhost:6379

# WhatsApp v0 (Evolution API)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# WhatsApp path de compliance (Cloud API)
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_ID=

# LinkedIn (Unipile)
UNIPILE_API_KEY=

# Voz (elegir proveedor en Fase 4)
RETELL_API_KEY=
VAPI_API_KEY=

# Google Calendar OAuth (por agente humano)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Enriquecimiento
APOLLO_API_KEY=

# Email
RESEND_API_KEY=
