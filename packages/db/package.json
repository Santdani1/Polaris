{
  "name": "@polaris/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --linked > src/database.types.ts",
    "db:seed": "tsx src/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@polaris/shared": "workspace:*",
    "@supabase/supabase-js": "^2.48.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
